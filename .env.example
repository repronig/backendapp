APP_NAME=REPRONIG
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
FRONTEND_URL=http://localhost:5173

# PostgreSQL is the supported database for this API (migrations rely on PG-specific constraints).
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=repronig
DB_USERNAME=postgres
DB_PASSWORD=

# Optional: SQLite is not recommended; some migrations only enforce CHECK constraints on PostgreSQL.
# DB_CONNECTION=sqlite
# DB_DATABASE=database/database.sqlite

QUEUE_CONNECTION=database
MAIL_MAILER=log
MAIL_TIMEOUT=30
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME="${APP_NAME}"
MAIL_SUPPORT_EMAIL=support@example.com
MAIL_ADMIN_NOTIFICATION_RECIPIENTS=
LICENSING_INVOICE_DUE_DAYS=14
LICENSING_INVOICE_DUE_SOON_DAYS=3

# WIPO Connect: "stub" (default, no outbound HTTP) or "http" (requires integration config: sync_url or api_base_url+sync_path, plus bearer_token or OAuth client credentials).
WIPO_CONNECT_DELIVERY=stub
WIPO_CONNECT_HTTP_TIMEOUT=30
# When true, inbound webhooks must send X-Repronig-Signature = hex HMAC-SHA256(raw JSON body, webhook_secret) instead of plain X-Repronig-Webhook-Secret.
WIPO_CONNECT_WEBHOOK_REQUIRE_HMAC=false
# Optional comma-separated IPs allowed to POST /api/v1/webhooks/wipo-connect; leave empty to allow any client IP.
WIPO_CONNECT_WEBHOOK_ALLOWED_IPS=

INTEGRATION_OUTBOX_MAX_ATTEMPTS=5
INTEGRATION_OUTBOX_RETRY_BACKOFF_BASE=60
INTEGRATION_OUTBOX_RETRY_BACKOFF_MAX=3600
INTEGRATION_OUTBOX_HEALTH_FAILED_WINDOW_HOURS=24
INTEGRATION_OUTBOX_HEALTH_FAILED_THRESHOLD=25
ONESIGNAL_APP_ID=
ONESIGNAL_API_KEY=

SMS_ENABLED=false
SMS_PROVIDER=termii
TERMII_BASE_URL=https://api.ng.termii.com
TERMII_API_KEY=
TERMII_SENDER_ID=REPRONIG

# Google reCAPTCHA v2 (member + institution registration). When RECAPTCHA_SECRET_KEY is set, API requires recaptcha_token on those endpoints.
# RECAPTCHA_SECRET_KEY=
# Public site key (same as Google “Site Key”); returned in GET /platform-settings so the SPA does not rely on Vite build-time env alone.
# RECAPTCHA_SITE_KEY=
